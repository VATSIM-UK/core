#!/usr/bin/env bash

# pre-commit hook for Laravel Pint
# Auto-fix files, but fail commit if anything was fixed.

if [ -f "$HOME/.bashrc" ]; then
    . "$HOME/.bashrc"
fi

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# Cross-platform PHP detection (MINGW64 uses php.bat)
PHP_BIN="php"
if command -v php.bat &>/dev/null 2>&1; then
    PHP_BIN="php.bat"
fi

# Cross-platform pint binary detection
PINT_BIN="vendor/bin/pint"
if [ ! -f "$PINT_BIN" ] && [ ! -f "${PINT_BIN}.bat" ]; then
    PINT_BIN="vendor/laravel/pint/builds/pint"
fi

# Collect PHP files: staged (pre-commit), or all tracked (prek run --all-files)
php_files=$(git diff --cached --name-only --diff-filter=ACM | { grep '\.php$' || true; })

if [ -z "$php_files" ]; then
    # Nothing staged — check all tracked PHP files (e.g. prek run --all-files)
    php_files=$(git ls-files '*.php' || true)
fi

[ -z "$php_files" ] && exit 0

# Use xargs to avoid "Argument list too long" with large file lists
echo "$php_files" | xargs "$PHP_BIN" "$PINT_BIN" --quiet --parallel || true

# Check if Pint changed any of the files
fixed_files=$(echo "$php_files" | xargs git diff --name-only --)

if [ -n "$fixed_files" ]; then
    echo
    echo "⚠️  Pint fixed some files. Please re-add them and commit again:"
    echo "$fixed_files"
    exit 1
fi

exit 0
