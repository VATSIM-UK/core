#!/usr/bin/env bash

# pre-commit hook for Laravel Pint
# Auto-fix files, but fail commit if anything was fixed.

if [ -f "$HOME/.bashrc" ]; then
    . "$HOME/.bashrc"
fi

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# Cross-platform PHP
PHP_BIN="php"
if command -v php.bat &>/dev/null 2>&1; then
    PHP_BIN="php.bat"
fi

# Cross-platform pint bin
PINT_BIN="vendor/bin/pint"
if [ ! -f "$PINT_BIN" ] && [ ! -f "${PINT_BIN}.bat" ]; then
    PINT_BIN="vendor/laravel/pint/builds/pint"
fi

php_files=$(git diff --cached --name-only --diff-filter=ACM | { grep '\.php$' || true; })

if [ -z "$php_files" ]; then
    php_files=$(git ls-files '*.php' || true)
fi

[ -z "$php_files" ] && exit 0

echo "$php_files" | xargs -n 50 "$PHP_BIN" "$PINT_BIN" --quiet --parallel || true

fixed_files=$(echo "$php_files" | xargs -n 100 git diff --name-only --)

if [ -n "$fixed_files" ]; then
    echo
    echo "⚠️  Pint fixed some files. Please re-add them and commit again:"
    echo "$fixed_files"
    exit 1
fi

exit 0
