#!/usr/bin/env bash

# pre-commit hook for Laravel Pint
# Auto-fix files, but fail commit if anything was fixed.

if [ -f "$HOME/.bashrc" ]; then
    . "$HOME/.bashrc"
fi

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if [ $# -gt 0 ]; then
    php_files=()
    for file in "$@"; do
        if [[ "$file" == *.php ]]; then
            php_files+=("$file")
        fi
    done
else
    mapfile -t php_files < <(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' || true)
fi

[ ${#php_files[@]} -eq 0 ] && exit 0

echo "Running Pint..."
php.bat vendor/laravel/pint/builds/pint --quiet "${php_files[@]}" || true

fixed_files=$(git diff --name-only -- "${php_files[@]}")

if [ -n "$fixed_files" ]; then
    echo
    echo "⚠️  Pint fixed some files. Please re-add them and commit again:"
    echo "$fixed_files"
    exit 1
fi

echo "✅ Pint made no changes."
exit 0
